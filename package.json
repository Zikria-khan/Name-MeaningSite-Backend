{
  "name": "nameverse-backend",
  "version": "1.0.0",
  "description": "Backend API for Nameverse - comprehensive name meanings database for Islamic, Christian, and Hindu names",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:filters": "jest --testPathPattern=test-filters"
  },
  "keywords": [
