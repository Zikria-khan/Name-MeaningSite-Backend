{
  "version": 2,
  "functions": {
    "api/index.js": {
      "runtime": "nodejs24.x",
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=86400, stale-while-revalidate=2592000" },
        { "key": "CDN-Cache-Control", "value": "public, s-maxage=86400" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, s-maxage=86400" }
      ]
    },
    {
      "source": "/api/v1/names(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=172800, stale-while-revalidate=2592000" }
      ]
    }
  ]
}
