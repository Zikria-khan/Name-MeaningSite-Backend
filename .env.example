# Server
PORT=5000
NODE_ENV=production
LOG_LEVEL=info

# Redis
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# MongoDB
MONGODB_URI=mongodb://localhost:27017/nameverse

# Rate Limiting
# Window: 15 minutes
# https://nameverse.vercel.app: 500 requests per 15 minutes
# All other origins: 100 requests per 15 minutes
# Health check endpoints (/health, /api/health) are exempt from rate limiting
DISABLE_RATE_LIMIT=false

# CORS
# Allow all origins (*)
# Rate limiting is based on origin/referer header
# https://nameverse.vercel.app gets higher limits
# All other origins have standard limits

# Performance
CACHE_TTL=3600
